{
  "extends": ["stylelint-config-standard"],
  "rules": {
    "selector-class-pattern": null,
    "custom-property-pattern": null
  },
  "ignoreFiles": [
    "**/*.ts",
    "**/*.tsx", 
    "**/*.js",
    "**/*.jsx",
    "**/*.json",
    "**/*.md",
    "node_modules/**/*",
    "dist/**/*",
    "build/**/*",
    "coverage/**/*",
    "src/**/*.ts",
    "src/**/*.tsx"
  ],
  "defaultSeverity": "warning"
}