# SonarQube Configuration
# Copy this file to .env and fill in your values
# Then run: source .env

# Required: Your SonarQube authentication token
SONAR_TOKEN=your-sonarqube-token-here

# Optional: SonarQube server URL (defaults to https://sonarqube.cdao.us)
SONAR_HOST_URL=https://sonarqube.cdao.us
