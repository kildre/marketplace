# NPM Registry Configuration
# This file configures npm to use the CDAO private registry for @advana scoped packages

# All @advana/* packages are hosted on the internal Nexus registry
# Requires VPN connection to nexus.cdao.us
@advana:registry=https://nexus.cdao.us/repository/npm-all/

# All other packages use the default public npm registry
registry=https://registry.npmjs.org/
