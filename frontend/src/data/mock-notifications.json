  "schema": {
    "Notification": {
      "id": "string (unique identifier)",
      "type": "request_submitted | request_approved | request_rejected | request_updated | system_alert | general",
      "priority": "low | medium | high | urgent",
      "title": "string (notification title)",
      "message": "string (notification message)",
      "read": "boolean (read status)",
      "createdAt": "string (ISO 8601 timestamp)",
      "actionUrl": "string (optional - URL to navigate to)",
      "requestId": "string (optional - associated request ID)",
      "requestorEmail": "string (optional - email of requestor)",
      "approverEmail": "string (optional - email of approver)",
      "recipientEmails": "array of strings (emails of users who can see this notification, empty array = all users for system_alert/general)",
      "metadata": "object (optional - additional data)"
    }
  },
  "accessRules": {
    "description": "Users can only see notifications where:",
    "rules": [
      "1. They are the requestor (requestorEmail matches their email)",
      "2. They are the approver (approverEmail matches their email)",
      "3. They are in the recipientEmails list",
      "4. The notification is system_alert or general type with empty recipientEmails (visible to all)"
    ]
  },
  "helperFunctions": {
    "getNotificationsForUser": "Returns only notifications visible to the specified user email",
    "getUnreadNotificationsForUser": "Returns only unread notifications visible to the specified user email"
  }
}
