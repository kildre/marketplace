# ============================================================================
# Frontend Environment Configuration
# ============================================================================

# ----------------------------------------------------------------------------
# Session Storage Configuration (NEW)
# ----------------------------------------------------------------------------
# Enable session-based authentication with backend
# When true: Frontend registers token once and uses session ID for requests
# When false: Frontend sends Keycloak token directly in every request
#
# Recommended: true for production, false for local development
VITE_USE_SESSION_STORAGE=false

# ----------------------------------------------------------------------------
# API Configuration
# ----------------------------------------------------------------------------
# Backend API base URL
# Development: http://localhost:8082 or empty (uses Vite proxy)
# Production: https://api.cdao.us or your backend URL
VITE_API_BASE_URL=http://localhost:8082

# ----------------------------------------------------------------------------
# Keycloak Configuration (Production)
# ----------------------------------------------------------------------------
# Keycloak server URL (with /auth if using older versions)
VITE_KEYCLOAK_URL=https://keycloak.cdao.us/auth

# Keycloak realm name
VITE_KEYCLOAK_REALM=baby-yoda

# Keycloak client ID for frontend (public client)
VITE_KEYCLOAK_CLIENT_ID=marketplace-ui

# Disable iframe-based login check (recommended for performance)
VITE_KEYCLOAK_CHECK_LOGIN_IFRAME=false

# ----------------------------------------------------------------------------
# Development Mode Configuration
# ----------------------------------------------------------------------------
# Bypass authentication in development (optional)
# WARNING: Never set to true in production!
VITE_BYPASS_AUTH=false

# ----------------------------------------------------------------------------
# Mock User Configuration (only used when VITE_BYPASS_AUTH=true)
# ----------------------------------------------------------------------------
# User Type - controls default roles
# Options: "admin" (both requestor and approver) or "requestor" (requestor only)
VITE_MOCK_USER_TYPE=requestor

# Or specify exact roles (comma-separated)
# VITE_MOCK_USER_ROLES=marketplace-requestor,marketplace-approver

# User Information
VITE_MOCK_USER_ID=dev-user-123
VITE_MOCK_USERNAME=kberres
VITE_MOCK_USER_EMAIL=kberres@advana.mil
VITE_MOCK_USER_FIRST_NAME=Kevin
VITE_MOCK_USER_LAST_NAME=Berres

# To test as an admin, change VITE_MOCK_USER_TYPE to "admin"
# VITE_MOCK_USER_TYPE=admin
# VITE_MOCK_USERNAME=admin
# VITE_MOCK_USER_EMAIL=admin@advana.mil
# VITE_MOCK_USER_FIRST_NAME=Admin
# VITE_MOCK_USER_LAST_NAME=User

# ============================================================================
# Environment-Specific Examples
# ============================================================================

# ----------------------------------------------------------------------------
# Local Development (Direct Token Mode - Recommended)
# ----------------------------------------------------------------------------
# VITE_USE_SESSION_STORAGE=false
# VITE_API_BASE_URL=http://localhost:8082
# VITE_KEYCLOAK_URL=http://localhost:8085/auth
# VITE_BYPASS_AUTH=false

# ----------------------------------------------------------------------------
# Local Development (Session Storage Mode - For Testing)
# ----------------------------------------------------------------------------
# VITE_USE_SESSION_STORAGE=true
# VITE_API_BASE_URL=http://localhost:8082
# VITE_KEYCLOAK_URL=http://localhost:8085/auth
# VITE_BYPASS_AUTH=false
# Note: Requires backend with USE_CLIENT_SESSION_STORAGE=true

# ----------------------------------------------------------------------------
# Production Environment
# ----------------------------------------------------------------------------
# VITE_USE_SESSION_STORAGE=true
# VITE_API_BASE_URL=https://api.cdao.us
# VITE_KEYCLOAK_URL=https://keycloak.cdao.us/auth
# VITE_KEYCLOAK_REALM=baby-yoda
# VITE_KEYCLOAK_CLIENT_ID=marketplace-ui
# VITE_BYPASS_AUTH=false

# ============================================================================
# Session Storage Mode Requirements
# ============================================================================
# When VITE_USE_SESSION_STORAGE=true, the backend must have:
# - USE_CLIENT_SESSION_STORAGE=true
# - PostgreSQL with session_tokens table
# - Endpoints: /api/session/register, /api/session/:id, /api/session/expire
#
# See BACKEND_SESSION_INTEGRATION.md for details
# ============================================================================
