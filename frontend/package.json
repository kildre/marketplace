{
  "name": "advana-marketplace",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=16.17.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "dev": "vite --port 8080",
    "build": "vite build",
    "build:il2": "vite build --mode il2",
    "build:il5": "vite build --mode il5",
    "build:localhost": "vite build --mode development",
    "preview": "vite preview --port 8080",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "test": "vitest --run",
    "test:coverage": "vitest --run --coverage",
    "test:watch": "vitest --watch",
    "test:a11y": "vitest --run --reporter=verbose -t \"accessibility|violations|axe|WCAG|ARIA\"",
    "test:verbose": "vitest --run --reporter=verbose",
    "beforepush": "npm run lint && npm run test"
  },
  "dependencies": {
    "@advana/platform-ui": "^3.1.0",
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@eslint/js": "^9.25.0",
    "@mui/icons-material": "^5.18.0",
    "@mui/material": "^5.18.0",
    "@mui/x-data-grid": "^8.10.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/api-logs": "^0.57.0",
    "@opentelemetry/auto-instrumentations-web": "^0.43.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.57.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.57.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.0",
    "@opentelemetry/instrumentation": "^0.57.0",
    "@opentelemetry/instrumentation-document-load": "^0.43.0",
    "@opentelemetry/instrumentation-fetch": "^0.57.0",
    "@opentelemetry/instrumentation-user-interaction": "^0.43.0",
    "@opentelemetry/resources": "^1.30.0",
    "@opentelemetry/sdk-logs": "^0.57.0",
    "@opentelemetry/sdk-metrics": "^1.30.0",
    "@opentelemetry/sdk-trace-base": "^1.30.0",
    "@opentelemetry/sdk-trace-web": "^1.30.0",
    "@opentelemetry/semantic-conventions": "^1.28.0",
    "@playwright/test": "^1.52.0",
    "@react-keycloak/web": "^3.4.0",
    "@reduxjs/toolkit": "^2.10.1",
    "@tanstack/react-query": "^5.83.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "16.3.0",
    "@testing-library/user-event": "14.6.1",
    "@types/react": "19.0.2",
    "@types/react-dom": "19.0.2",
    "@vitejs/plugin-react": "4.5.2",
    "@vitest/coverage-v8": "^3.2.3",
    "exceljs": "^4.4.0",
    "file-saver": "^2.0.5",
    "keycloak-js": "^26.2.0",
    "platform-ui": "^0.0.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^6.28.0",
    "redux-persist": "^6.0.0"
  },
  "devDependencies": {
    "@axe-core/react": "^4.10.2",
    "@testing-library/dom": "^10.4.1",
    "@types/file-saver": "^2.0.7",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^22.14.0",
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6",
    "@typescript-eslint/eslint-plugin": "^8.35.1",
    "@typescript-eslint/parser": "^8.35.1",
    "eslint": "9.28.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jest-axe": "^10.0.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.7.4",
    "sass": "^1.86.3",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.1.3"
  }
}
